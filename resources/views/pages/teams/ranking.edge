      <div class="flex border font-manrope font-bold">

        <!-- COLONNE FIXE EQUIPE  -->

        <div class="shrink-0 bg-white ml-1">

          <!-- HEADER -->
          <div class="h-14 flex items-center justify-center border-b border-r px-4 bg-white">
            Equipes
          </div>

          <!-- BODY -->
          @each(team in ranking)
            <div
              class="h-14 flex items-center border-r px-4 {{ gender === 'F' ? 'even:bg-[#da0f83]/20' : 'even:bg-[#0065a0]/20' }}"
            >
              <div class="flex items-center gap-3">

                <span class="w-6 text-center">
                  {{ team.position }}
            </span>

                <img
                  class="h-8 w-8 object-contain"
                  src="{{ team.logo && !team.logo.includes('defaultLogo') ? team.logo : '/img/logo-ffbb.jpg' }}"
                  alt=""
                />

                <span class="text-xs whitespace-nowrap">
                  {{ team.equipe }}
            </span>

              </div>
            </div>
          @end
            
        </div>

        <!-- PARTIE SCROLLABLE     -->

        <div class="overflow-x-auto w-full">

          <div class="min-w-max">

            <!-- HEADER -->
            <div class="grid grid-cols-3 h-14 items-center min-w-160 border-b bg-white">

              <div class=" text-center ">
                PTS
              </div>
              <div class="flex justify-between w-30">
                <div class="px-1 text-center">
                  J
                </div>
                <div class="px-1 text-center">
                  G
                </div>
                <div class="px-1 text-center">
                  P
                </div>
                <div class="px-1 text-center">
                  N
                </div>
              </div>
              <div class="flex justify-between w-30">
                <div class="px-1 text-center">
                  M
                </div>
                <div class="px-1 text-center">
                  E
                </div>
                <div class="px-1 text-center">
                  D
                </div>
              </div>

            </div>

            <!-- BODY -->
            @each(team in ranking)
              <div
                class="grid grid-cols-3 h-14 items-center {{ gender === 'F' ? 'even:bg-[#da0f83]/20' : 'even:bg-[#0065a0]/20' }}"
              >

                <div class="text-center opacity-70 mx-1">
                  {{ team.points }}
                </div>
                <div class="flex justify-between w-30">
                  <div class="px-1 text-center opacity-70">
