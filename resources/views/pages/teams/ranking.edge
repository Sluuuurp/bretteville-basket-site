@layout('components.layout')

  @slot('main')

    <h1 class="my-10 ml-2 sm:ml-auto container mx-auto font-teko font-bold uppercase text-3xl pl-1">
      Classement - {{ currentTeam?.nom }}
    </h1>

    <section class="container mx-auto my-10">
      <a
