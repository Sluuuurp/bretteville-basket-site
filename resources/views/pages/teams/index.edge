<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @vite(['resources/css/app.css', 'resources/js/app.js'])
    <title>
      Document
    </title>
  </head>
  <body>
    <h1 class="font-timeline text-center bg-yellow-400 uppercase text-3xl">
      liste equipes test
    </h1>
    <ul>
      @each(team in teams)
        <li class="border my-4 py-2 cursor-pointer team-item" data-link="{{ team.lien }}">

          <div class="flex gap-4">
            @if(team.image)
              <img src="{{ team.image }}" alt="{{ team.nom }}" width="80" />
            @endif
            
            <div>
              <h3>
                {{ team.nom }}
              </h3>
              <p>
                {{ team.tabData.join(' | ') }}
              </p>
            </div>
          </div>

          <!-- zone repliée avec structure déjà créée -->
          <div class="calendar hidden mt-3">
            <div class="loading">
              Chargement...
            </div>
            <div class="matches grid gap-2 mt-2">

            </div>
          </div>
        </li>
      @endeach
    </ul>

  </body>
</html>
