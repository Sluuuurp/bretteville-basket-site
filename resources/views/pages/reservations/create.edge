<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @vite(['resources/css/app.css', 'resources/js/app.js'])
    <title>
      Document
    </title>
  </head>
  <body>
    @if (flashMessages.has('success'))
      <div class="p-3 mb-4 bg-green-100 text-green-700 rounded">
        {{ flashMessages.get('success') }}
      </div>
    @endif
    
    @if (flashMessages.has('error'))
      <div class="p-3 mb-4 bg-red-100 text-red-700 rounded">
        {{ flashMessages.get('error') }}
      </div>
    @endif
    
    
    
    <section>
      <h3>
        Ajouter un article
      </h3>

      <select id="select-article">
        @each(article in articlesList)
          <option value="{{ article.id }}" data-price="{{ article.price }}">
            {{ article.name }} - {{ article.price }}€
          </option>
        @endeach
      </select>
      <select id="select-size">
        <option>
          S
        </option>
        <option>
          M
        </option>
        <option>
          L
        </option>
        <option>
          XL
        </option>
      </select>

      <input type="number" id="select-qty" min="1" value="1" />

      <button type="button" id="add-to-cart">
        Ajouter au panier
  </button>
    </section>
    <hr class="py-10" />
    <form action="/reservations/store" method="post">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

      <!-- coordonnées -->
      {{-- coordonnées --}}
      <div>
        <label for="lastname">Nom</label>
        <input type="text" name="lastname" required class="input border" />

        <label for="firstname">Prénom</label>
        <input type="text" name="firstname" required class="input border" />

        <label for="email">Email</label>
        <input type="email" name="email" required class="input border" />

        <label for="phone">Téléphone (optionnel)</label>
        <input type="tel" name="phone" class="input border" />
      </div>
      <hr class="py-10" />
      <h3>
        Votre panier
      </h3>
      <div id="cart">
      </div>

      <p id="empty-cart">
        Votre panier est vide
      </p>

      <button type="submit">Réserver</button>
    </form>

    <script>
      const cart = [];

      const cartContainer = document.getElementById("cart");

      const emptyCart = document.getElementById("empty-cart");

      function renderCart() {
        cartContainer.innerHTML = "";
        emptyCart.style.display = cart.length ? "none" : "block";
        cart.forEach((item, index) => {
          cartContainer.insertAdjacentHTML("beforeend", `
                                                                                                                                          <div>
                                                                                                                                            ${item.name} - ${item.size} × ${item.quantity}

                                                                                                                                            <input type="hidden" name="items[${index}][articleId]" value="${item.articleId}">
                                                                                                                                            <input type="hidden" name="items[${index}][size]" value="${item.size}">
                                                                                                                                            <input type="hidden" name="items[${index}][quantity]" value="${item.quantity}">

                                                                                                                                            <button type="button" onclick="removeItem(${index})">✕</button>
                                                                                                                                          </div>
                                                                                                                                        `);
        });
      }

      function removeItem(index) {
        cart.splice(index, 1);
        renderCart();
      }
      //add au panier;

      document.getElementById("add-to-cart").addEventListener("click", () => {
        const articleSelect = document.getElementById("select-article");
        const size = document.getElementById("select-size").value;
        const quantity = Number(document.getElementById("select-qty").value);
        cart.push({
          articleId: articleSelect.value,
          name: articleSelect.options[articleSelect.selectedIndex].text,
          size: size,
          quantity: quantity
        });
        renderCart();
      });
    </script>

  </body>
</html>

