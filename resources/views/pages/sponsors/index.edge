<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @vite(['resources/css/app.css', 'resources/js/app.js'])
    <title>
      Document
    </title>
  </head>
  <body>

    <a href="/sponsors/creation" class="btn-primary mb-4 inline-block">Ajouter un sponsor</a>

    @if(flashMessages.has('success'))
      <div class="p-2 mb-4 text-green-700 bg-green-100 rounded">
        {{ flashMessages.get('success') }}
      </div>
    @endif
    
    <h1 class="text-2xl font-bold mb-4">
      Liste des sponsors
    </h1>

    @if(sponsorsList.length === 0)
      <p>
        Aucun sponsors pour le moment.
      </p>
    @else
      <div class="grid gap-4">
        @each(sponsor in sponsorsList)
          <div class="p-4 border rounded shadow-sm">
            <h2 class="text-xl font-semibold">
              {{ sponsor.nom_ent }}
            </h2>
            <p class="text-gray-700">
              {{ sponsor.ville }}
            </p>

            <p>
              {{ sponsor.lien }}
            </p>

            <a href="/sponsors/{{ sponsor.id }}/edit" class="text-blue-600 underline">Modifier</a>

            <form method="POST" action="/sponsors/{{ sponsor.id }}?_method=DELETE">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
              <button class="btn-danger" onclick="return confirm('Supprimer ce sponsor ?')">Supprimer</button>
            </form>

          </div>
        @endeach
      </div>
    @endif
    
      
  </body>
</html>
