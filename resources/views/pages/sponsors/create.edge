<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @vite(['resources/css/app.css', 'resources/js/app.js'])
    <title>
      Document
    </title>
  </head>
  <body>
    <form action="/sponsors/store" method="POST" enctype="multipart/form-data" class="flex flex-col gap-4">
      <!-- CSRF -->
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

      <!-- Nom -->
      <div>
        <label for="nom_ent" class=" text-sm font-medium">Nom de l'entreprise</label>
        <input type="text" name="nom_ent" required maxlength="250" class="input border" />
      </div>

      <!-- ville -->
      <div class="flex flex-col">
        <label for="ville" class=" text-sm font-medium">ville/commune</label>
        <input type="text" name="ville" required maxlength="250" class="input border" />
      </div>

      <!-- lien -->
      <div class="flex flex-col">
        <label for="lien" class=" text-sm font-medium">Lien site entreprise(optionnel)</label>
        <input type="text" name="lien" class="input border" />
      </div>

      <!-- Submit -->
      <button type="submit" class="btn-primary border">
        Créer le sponsor
  </button>

      @if (flashMessages.has('success'))
        <div class="p-2 mb-4 text-green-700 bg-green-100 rounded">
          {{ flashMessages.get('success') }}
        </div>
      @endif
      
      @if(flashMessages.has('errors'))
        <ul class="text-red-500">
          @each(error in flashMessages.get('errors'))
            <li>
              {{ error.message }}
            </li>
          @endeach
        </ul>
      @endif
      
    </form>

  </body>
</html>

