<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @vite(['resources/css/app.css', 'resources/js/app.js'])
    <title>
      Document
    </title>
  </head>
  <body>

    <a href="/evenements/creation" class="btn-primary mb-4 inline-block">Créer un événement</a>

    @if(flashMessages.has('success'))
      <div class="p-2 mb-4 text-green-700 bg-green-100 rounded">
        {{ flashMessages.get('success') }}
      </div>
    @endif
    
    <h1 class="text-2xl font-bold mb-4">
      Liste des événements
    </h1>

    @if(eventList.length === 0)
      <p>
        Aucun événement pour le moment.
      </p>
    @else
      <div class="grid gap-4">
        @each(event in eventList)
          <div class="p-4 border rounded shadow-sm">
            <h2 class="text-xl font-semibold">
              {{ event.title }}
            </h2>
            <p class="text-gray-700">
              {{ event.content }}
            </p>

            @if(event.images)
              <div class="flex gap-2 mt-2">
                @each(image in event.images)
                  <img
                    src="/uploads/{{ image.path }}"
                    class="w-24 h-24 object-cover rounded"
                    alt="{{ image.alt ?? event.title }}"
                  />
                @endeach
              </div>
            @endif
          </div>
        @endeach
      </div>
    @endif
    
      
  </body>
</html>
