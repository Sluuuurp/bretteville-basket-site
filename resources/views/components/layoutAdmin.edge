<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @vite(['resources/css/app.css', 'resources/js/app.js'])
    <title>
      {{ pageTitle || '' }} - administration
    </title>

  </head>
  <body>

    <header
      class="bg-[url('/img/board.png')] flex justify-center md:justify-between w-full items-center relative h-30 sm:h-40 overflow-hidden"
    >

      {{-- logo fond transparent --}}
      <img
        src="/public/img/logo-bbc.png"
        class="min-w-120 w-180 absolute  md:-right-89.5 -top-20 sm:-top-22 opacity-40"
        alt=""
      />

      <div class="relative ml-5 xl:ml-20">
        <img src="/public/img/logo-parchemin.png" class="max-h-40 hidden md:block" alt="logo-parchemin" />
        <h1 class="max-w-60  sm:hidden text-xl text-white text-center font-timeline">
          Bretteville Basket Cingal
        </h1>
        <h1
          class="absolute top-10/12 xl:-left-8 font-timeline text-[0.55rem] xl:text-[0.7rem] hidden md:block"
        >
          Bretteville&nbsp;basket&nbsp;cingal
        </h1>
      </div>

      <nav class="hidden sm:block md:mr-4 xl:mr-20">

        <ul
          class="flex gap-2 md:gap-5 xl:gap-10 uppercase font-timeline text-[0.8rem] md:text-[0.95rem] xl:text-[1.2rem] text-white"
        >
          <li class="bg-black py-1 px-5 [clip-path:polygon(10%_0,100%_0,90%_100%,0_100%)] relative group">
            <a href="/" class="">accueil</a>
            <span class="absolute bottom-0 left-0 w-0 h-1.5 bg-roses group-hover:w-full"></span>
          </li>
          <li class="bg-black py-1 px-5 [clip-path:polygon(10%_0,100%_0,90%_100%,0_100%)] relative group">
            <a href="/articles">boutique</a>
            <span class="absolute bottom-0 left-0 w-0 h-1.5 bg-roses group-hover:w-full"></span>
          </li>
          <li class="bg-black py-1 px-5 [clip-path:polygon(10%_0,100%_0,90%_100%,0_100%)] relative group">
            <a href="/equipes">Equipes</a>
            <span class="absolute bottom-0 left-0 w-0 h-1.5 bg-roses group-hover:w-full"></span>
          </li>
          <li class="bg-black py-1 px-5 [clip-path:polygon(10%_0,100%_0,90%_100%,0_100%)] relative group">
            <a href="/evenements">evenements</a>
            <span class="absolute bottom-0 left-0 w-0 h-1.5 bg-roses group-hover:w-full"></span>
          </li>
        </ul>
      </nav>
    </header>
    {{-- -------------------------- CONTENU --------------------------------- --}}
    <main>
      {{{ await $slots.main() }}}
    </main>

  </body>

</html>
